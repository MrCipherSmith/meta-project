{
  "name": "gd-metapro",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "gd-metapro": "./dist/cli.js"
  },
  "scripts": {
    "gd-metapro": "bun ./src/cli.ts",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "prepack": "bun run build",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "tsc --noEmit && bun test"
  },
  "files": [
    "dist",
    "src/gdgraph",
    "src/gdskills/bundled",
    "src/gdskills/contracts",
    "README.md",
    "package.json"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
