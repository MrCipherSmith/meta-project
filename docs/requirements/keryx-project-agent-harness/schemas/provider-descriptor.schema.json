{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.local/schemas/harness/provider-descriptor.schema.json",
  "title": "Keryx Harness Provider Descriptor",
  "description": "Provider capability descriptor. Release 0 requires fake/offline provider settings; remote storage or continuation may not be enabled without a separately approved capability, retention, and deletion contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "providerId", "providerRevision", "models", "capabilities", "remoteState"],
  "properties": {
    "schemaVersion": { "$ref": "harness-envelope.schema.json#/$defs/schemaVersion" },
    "providerId": { "$ref": "harness-envelope.schema.json#/$defs/id" },
    "providerRevision": { "type": "string", "minLength": 1 },
    "models": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["modelId", "revision"], "properties": { "modelId": { "type": "string", "minLength": 1 }, "revision": { "type": "string", "minLength": 1 } } } },
    "capabilities": { "type": "object", "additionalProperties": false, "required": ["streaming", "tools", "parallelToolCalls", "cancellation"], "properties": { "streaming": { "type": "boolean" }, "tools": { "type": "boolean" }, "parallelToolCalls": { "type": "boolean" }, "cancellation": { "type": "boolean" }, "structuredOutput": { "type": "boolean" } } },
    "remoteState": { "type": "object", "additionalProperties": false, "required": ["storage", "retention", "continuation"], "properties": { "storage": { "type": "boolean", "const": false }, "retention": { "type": "boolean", "const": false }, "continuation": { "type": "boolean", "const": false } } }
  }
}
