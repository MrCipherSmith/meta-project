{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.local/schemas/harness/fixtures/fixture-matrix.json",
  "title": "Keryx Harness Contract Fixture Matrix",
  "description": "Compact fixture registry. Each family has a positive and negative case at a deterministic JSON Pointer in the two catalogs. A Draft 2020-12 validator must validate the pointed case against the listed schema; semanticOnly describes assertions outside JSON Schema.",
  "schemaVersion": 1,
  "positiveCatalog": "positive-contract-catalog.json",
  "negativeCatalog": "negative-contract-catalog.json",
  "families": [
    { "schema": "harness-envelope.schema.json", "positive": "#/cases/envelope", "negative": "#/cases/envelope-missing-version" },
    { "schema": "harness-config.schema.json", "positive": "#/cases/config", "negative": "#/cases/config-bad-limit" },
    { "schema": "harness-context-manifest.schema.json", "positive": "#/cases/context-manifest", "negative": "#/cases/context-manifest-bad-hash" },
    { "schema": "harness-run-input.schema.json", "positive": "#/cases/run-input", "negative": "#/cases/run-input-missing-budget" },
    { "schema": "harness-run-output.schema.json", "positive": "#/cases/run-output-completed", "negative": "#/cases/run-output-evidence-free-completed" },
    { "schema": "harness-event.schema.json", "positive": "#/cases/event", "negative": "#/cases/event-untyped-payload" },
    { "schema": "harness-tool-call.schema.json", "positive": "#/cases/tool-call", "negative": "#/cases/tool-call-invalid-risk" },
    { "schema": "harness-policy-decision.schema.json", "positive": "#/cases/policy-decision", "negative": "#/cases/policy-ask-unbound" },
    { "schema": "session-manifest.schema.json", "positive": "#/cases/session-manifest", "negative": "#/cases/session-manifest-no-leaf" },
    { "schema": "session-entry.schema.json", "positive": "#/cases/session-entry", "negative": "#/cases/session-entry-ambiguous-union" },
    { "schema": "provider-descriptor.schema.json", "positive": "#/cases/provider-descriptor", "negative": "#/cases/provider-remote-state-enabled" },
    { "schema": "model-request.schema.json", "positive": "#/cases/model-request", "negative": "#/cases/model-request-no-attempt" },
    { "schema": "model-response.schema.json", "positive": "#/cases/model-response", "negative": "#/cases/model-response-no-events" },
    { "schema": "model-error.schema.json", "positive": "#/cases/model-error", "negative": "#/cases/model-error-permanent-retry" },
    { "schema": "tool-definition.schema.json", "positive": "#/cases/tool-definition", "negative": "#/cases/tool-definition-invalid-version" },
    { "schema": "tool-registry-snapshot.schema.json", "positive": "#/cases/tool-registry", "negative": "#/cases/tool-registry-no-tools" },
    { "schema": "tool-execution-state.schema.json", "positive": "#/cases/tool-execution-succeeded", "negative": "#/cases/tool-execution-terminal-without-result" },
    { "schema": "tool-result.schema.json", "positive": "#/cases/tool-result", "negative": "#/cases/tool-result-failure-no-code" },
    { "schema": "execution-receipt.schema.json", "positive": "#/cases/execution-receipt", "negative": "#/cases/execution-receipt-no-evidence" },
    { "schema": "policy-profile.schema.json", "positive": "#/cases/policy-profile-release0", "negative": "#/cases/policy-profile-release0-write" },
    { "schema": "approval-request.schema.json", "positive": "#/cases/approval-request", "negative": "#/cases/approval-request-no-binding" },
    { "schema": "approval-result.schema.json", "positive": "#/cases/approval-result", "negative": "#/cases/approval-result-approved-unconsumed" },
    { "schema": "evidence-record.schema.json", "positive": "#/cases/evidence-record", "negative": "#/cases/evidence-record-no-provenance" },
    { "schema": "evidence-ledger.schema.json", "positive": "#/cases/evidence-ledger", "negative": "#/cases/evidence-ledger-no-cursor" },
    { "schema": "checkpoint.schema.json", "positive": "#/cases/checkpoint", "negative": "#/cases/checkpoint-no-state-hash" },
    { "schema": "branch-metadata.schema.json", "positive": "#/cases/branch-metadata", "negative": "#/cases/branch-metadata-no-ancestors" },
    { "schema": "compaction-entry.schema.json", "positive": "#/cases/compaction-entry", "negative": "#/cases/compaction-entry-no-evidence-cursor" },
    { "schema": "completion-gate-result.schema.json", "positive": "#/cases/completion-gate-pass", "negative": "#/cases/completion-gate-pass-failed-check" },
    { "schema": "rpc-jsonl-envelope.schema.json", "positive": "#/cases/rpc-envelope", "negative": "#/cases/rpc-envelope-no-correlation" },
    { "schema": "fake-provider-transcript.schema.json", "positive": "#/cases/fake-provider-transcript", "negative": "#/cases/fake-provider-nonfake" },
    { "schema": "replay-fixture.schema.json", "positive": "#/cases/replay-fixture", "negative": "#/cases/replay-with-effects" },
    { "schema": "replay-mismatch.schema.json", "positive": "#/cases/replay-mismatch", "negative": "#/cases/replay-mismatch-no-actual" },
    { "schema": "harness-child-contract-extension.schema.json", "positive": "#/cases/child-contract-extension", "negative": "#/cases/child-contract-extension-no-canonical" }
  ],
  "semanticOnly": ["causal reference existence", "append-only sequence and ancestor immutability", "hash recomputation", "single-use approval consumption", "no-side-effect replay enforcement", "Task Manager completion ownership"]
}
