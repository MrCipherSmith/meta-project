{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.local/schemas/harness/harness-envelope.schema.json",
  "title": "Keryx Harness Shared Contract Definitions",
  "description": "Reusable Draft 2020-12 definitions. Every durable harness contract has schemaVersion 1 and a stable HTTPS $id. Cross-record causal and append-only properties require semantic validation in addition to schema validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": { "$ref": "#/$defs/schemaVersion" }
  },
  "$defs": {
    "schemaVersion": { "type": "integer", "const": 1, "description": "Contract major version; incompatible changes require a new schemaVersion and $id." },
    "id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactId", "kind", "hash"],
      "properties": {
        "artifactId": { "$ref": "#/$defs/id" },
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provenanceId", "trustLevel", "sourceKind"],
      "properties": {
        "provenanceId": { "$ref": "#/$defs/id" },
        "trustLevel": { "type": "string", "enum": ["trusted", "untrusted", "derived", "unknown"] },
        "sourceKind": { "type": "string", "minLength": 1 },
        "sourceHash": { "$ref": "#/$defs/sha256" },
        "taintIds": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true }
      }
    },
    "causalIds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "sessionId", "correlationId"],
      "properties": {
        "runId": { "$ref": "#/$defs/id" },
        "sessionId": { "$ref": "#/$defs/id" },
        "correlationId": { "$ref": "#/$defs/id" },
        "parentEventId": { "type": ["string", "null"], "minLength": 1 },
        "attemptId": { "$ref": "#/$defs/id" },
        "branchId": { "$ref": "#/$defs/id" }
      }
    },
    "policyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyProfileId", "policyFingerprint", "actionFingerprint", "provenanceId"],
      "properties": {
        "policyProfileId": { "$ref": "#/$defs/id" },
        "policyFingerprint": { "$ref": "#/$defs/sha256" },
        "actionFingerprint": { "$ref": "#/$defs/sha256" },
        "provenanceId": { "$ref": "#/$defs/id" }
      }
    },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  }
}
