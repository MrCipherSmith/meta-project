{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.local/schemas/harness/tool-registry-snapshot.schema.json",
  "title": "Keryx Harness Tool Registry Snapshot",
  "description": "Immutable version-bound registry snapshot. Hash recomputation and tool implementation identity require semantic validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "snapshotId", "createdAt", "registryHash", "tools"],
  "properties": {
    "schemaVersion": { "$ref": "harness-envelope.schema.json#/$defs/schemaVersion" },
    "snapshotId": { "$ref": "harness-envelope.schema.json#/$defs/id" },
    "createdAt": { "$ref": "harness-envelope.schema.json#/$defs/timestamp" },
    "registryHash": { "$ref": "harness-envelope.schema.json#/$defs/sha256" },
    "tools": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["toolId", "version", "definitionHash"], "properties": { "toolId": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "definitionHash": { "$ref": "harness-envelope.schema.json#/$defs/sha256" } } } }
  }
}
