{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.dev/schemas/credential-reference/1.0.0",
  "title": "Credential Reference",
  "description": "Opaque reference to an OS credential-store secret; never contains secret material.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "provider", "key"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "provider": { "enum": ["os-credential-store"] },
    "key": { "type": "string", "minLength": 1, "maxLength": 256 },
    "account": { "type": "string", "minLength": 1, "maxLength": 256 },
    "rotatedAt": { "type": "string", "format": "date-time" }
  },
  "not": { "required": ["token"] }
}
