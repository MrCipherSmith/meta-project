{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.dev/schemas/normalized-inbound-update-receipt/1.0.0",
  "title": "Normalized Inbound Update Receipt",
  "description": "Bounded, provider-neutral record. Raw Telegram payload is intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updateId", "kind", "chatId", "telegramUserId", "receivedAt", "correlationId"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "updateId": { "type": "integer", "minimum": 0 },
    "kind": { "enum": ["start", "command", "callback", "unsupported"] },
    "chatId": { "type": "integer" },
    "telegramUserId": { "type": "integer" },
    "text": { "type": "string", "maxLength": 4096 },
    "callbackData": { "type": "string", "maxLength": 64 },
    "receivedAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "callback" } }, "required": ["kind"] },
      "then": { "required": ["callbackData"] }
    }
  ]
}
