{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-implementer-input-contract",
  "title": "Task Implementer Input Contract",
  "description": "Defines all input parameters required to run task-implementer skill autonomously. Receives a single Gherkin Scenario from issue-analyzer plus workspace context.",
  "type": "object",
  "required": ["task", "workspace", "automation"],
  "properties": {
    "task": {
      "type": "object",
      "description": "The atomic task to implement, extracted from issue-analyzer Gherkin Scenario.",
      "required": ["task_id", "task_name", "task_type", "description", "target_files", "acceptance_criteria"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^task-\\d+$",
          "description": "Unique task identifier from issue-analyzer",
          "examples": ["task-1", "task-3"]
        },
        "task_name": {
          "type": "string",
          "description": "Descriptive name of the task",
          "examples": ["Add validation to pipeline form"]
        },
        "task_type": {
          "type": "string",
          "enum": ["ui_component", "store_logic", "service_api", "refactoring", "fix", "mixed"],
          "description": "Type of implementation task"
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium",
          "description": "Estimated complexity"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^task-\\d+$"
          },
          "default": [],
          "description": "Task IDs this task depends on (already completed)"
        },
        "description": {
          "type": "string",
          "description": "Full description of what to implement"
        },
        "target_files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "File paths to modify or create",
          "examples": [["src/pipelines/components/StepForm.tsx", "src/pipelines/stores/step.store.ts"]]
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Criteria that must be met for task to be considered complete"
        },
        "context": {
          "type": "string",
          "description": "Relevant code context: key types, function signatures, patterns"
        },
        "existing_tests": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Paths to existing test files (empty array if none)"
        },
        "existing_stories": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Paths to existing story files (empty array if none)"
        },
        "module_patterns": {
          "type": "string",
          "description": "Notes on how similar code is written in the module"
        }
      }
    },
    "workspace": {
      "type": "object",
      "description": "Workspace context managed by the orchestrator.",
      "required": ["codebase_path", "branch", "issue_number"],
      "properties": {
        "codebase_path": {
          "type": "string",
          "description": "Absolute path to the repository root",
          "examples": ["/Users/dev/<PROJECT>"]
        },
        "branch": {
          "type": "string",
          "description": "Feature branch to work on (already created and checked out by orchestrator)",
          "examples": ["feature/4141-add-pipeline-validation"]
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1,
          "description": "GitHub issue number for commit references"
        },
        "issue_title": {
          "type": "string",
          "description": "GitHub issue title for context"
        }
      }
    },
    "fix_context": {
      "type": "object",
      "description": "Present only for fix tasks dispatched from review loop.",
      "properties": {
        "review_feedback": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "severity", "message"],
            "properties": {
              "file": {
                "type": "string",
                "description": "File path where the issue was found"
              },
              "line": {
                "type": "integer",
                "description": "Line number (if available)"
              },
              "severity": {
                "type": "string",
                "enum": ["CRITICAL", "WARNING", "INFO"],
                "description": "Severity of the finding"
              },
              "message": {
                "type": "string",
                "description": "Review finding description"
              },
              "reviewer": {
                "type": "string",
                "description": "Which review skill found this",
                "examples": ["code-ai-review", "code-boss-review", "code-style-review"]
              }
            }
          },
          "description": "Structured findings from review skills"
        },
        "original_task_id": {
          "type": "string",
          "pattern": "^task-\\d+$",
          "description": "The task that introduced the issues"
        },
        "iteration": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2,
          "description": "Fix iteration number (max 2)"
        }
      }
    },
    "automation": {
      "type": "object",
      "description": "Controls for autonomous execution.",
      "required": ["skip_confirmation"],
      "properties": {
        "skip_confirmation": {
          "type": "boolean",
          "const": true,
          "description": "Must be true for autonomous mode"
        },
        "auto_commit": {
          "type": "boolean",
          "default": true,
          "description": "Automatically commit changes after implementation"
        },
        "verify_lint": {
          "type": "boolean",
          "default": true,
          "description": "Run ESLint after implementation"
        },
        "verify_types": {
          "type": "boolean",
          "default": true,
          "description": "Run type-check after implementation"
        },
        "verify_tests": {
          "type": "boolean",
          "default": true,
          "description": "Run tests after implementation"
        },
        "verify_stories": {
          "type": "boolean",
          "default": false,
          "description": "Build storybook to verify stories compile"
        },
        "max_self_fix_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3,
          "description": "Max attempts to fix verification failures"
        }
      }
    }
  }
}
