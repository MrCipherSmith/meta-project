{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.local/schemas/gdskills/subagent-dispatch.schema.json",
  "title": "Metaproject Subagent Dispatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_id",
    "dispatch_id",
    "orchestrator",
    "target_skill",
    "task",
    "acceptance_criteria",
    "context_refs",
    "files_to_read",
    "constraints",
    "allowed_actions",
    "output_contract",
    "budget",
    "provenance"
  ],
  "properties": {
    "contract_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "run_id": { "type": "string", "minLength": 1 },
    "dispatch_id": { "type": "string", "minLength": 1 },
    "parent_dispatch_id": { "type": ["string", "null"] },
    "orchestrator": { "type": "string", "minLength": 1 },
    "target_skill": { "type": "string", "minLength": 1 },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "intent": { "type": "string" },
        "scope": { "type": "string" }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "context_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_ref" }
    },
    "files_to_read": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read", "write", "run-command", "network", "git", "ask-user", "spawn-subagent"]
      }
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "artifact_path"],
      "properties": {
        "schema": { "type": "string" },
        "artifact_path": { "type": "string" },
        "summary_max_tokens": { "type": "integer", "minimum": 50 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_prompt_tokens": { "type": ["integer", "null"], "minimum": 1000 },
        "max_output_tokens": { "type": ["integer", "null"], "minimum": 500 },
        "max_runtime_ms": { "type": ["integer", "null"], "minimum": 1000 },
        "max_findings": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "tier": { "type": "string", "minLength": 1 },
        "inherit": { "type": "boolean" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "source_request": { "type": "string" }
      }
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "exists"],
      "properties": {
        "path": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["context", "graph", "wiki", "memory", "health", "diff", "report", "plan", "review", "custom"]
        },
        "exists": { "type": "boolean" },
        "summary": { "type": "string" },
        "hash": { "type": ["string", "null"] }
      }
    }
  }
}
